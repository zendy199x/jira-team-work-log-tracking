# =========================
# JIRA (required)
# =========================
# Shared team/project key used in report title and Jira JQL project filter.
TEAM_NAME=TEAM # e.g. BKM4, etc.
JIRA_DOMAIN=your-domain.atlassian.net # e.g. oneline.atlassian.net
JIRA_EMAIL=your_email@example.com # Email associated with the Jira account used for API access
JIRA_API_TOKEN=your_jira_api_token # Generate at https://id.atlassian.com/manage-profile/security/api-tokens

# Protects /reports/run, /reports/retry, and /api/cron endpoints (required for Vercel cron)
CRON_SECRET=replace_with_long_random_secret # Generate a long random string, e.g. using `openssl rand -hex 32`


# =========================
# CHAT DELIVERY MODE (default: webhook)
# =========================
# webhook: use incoming webhook URL
# app: use Google Chat App + service account
GOOGLE_CHAT_MODE=webhook # Supported values: webhook, app
# Required only when GOOGLE_CHAT_MODE=webhook
WEBHOOK=https://chat.googleapis.com/v1/spaces/xxx/messages?key=xxx&token=xxx # Example format: https://chat.googleapis.com/v1/spaces/AAAA12345/messages?key=xxx&token=xxx

# Required only when GOOGLE_CHAT_MODE=app
# Format example: spaces/AAAA12345
GOOGLE_CHAT_SPACE=
GOOGLE_CHAT_SERVICE_ACCOUNT_EMAIL=
# Keep newline escaped as \n in .env
GOOGLE_CHAT_SERVICE_ACCOUNT_PRIVATE_KEY=

# =========================
# OPTIONAL
# =========================
# Preferred timezone for report time/date rendering.
# If set, REPORT_TIMEZONE has highest priority.
REPORT_TIMEZONE=Asia/Ho_Chi_Minh

# Fallback timezone when REPORT_TIMEZONE is empty.
TZ=Asia/Ho_Chi_Minh

# Force report for a specific date (YYYY-MM-DD). Leave empty for today in TZ.
REPORT_DATE=

# Enable detailed work log aggregation debug logs.
# Supported truthy values: 1, true, yes, on
REPORT_DEBUG=

# Optional author filter for debug logs, comma-separated.
# Example: Tyler,Leser,Lien Mach
REPORT_DEBUG_AUTHORS=

# Optional API base path. Keep empty to auto-detect on Vercel.
# API_BASE_PATH=/api
API_BASE_PATH=