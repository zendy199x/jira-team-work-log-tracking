{
  "name": "jira-team-work-log-tracking",
  "version": "1.0.0",
  "license": "MIT",
  "private": false,
  "description": "NestJS API for Jira team work log tracking with Google Chat integration and Vercel cron",
  "author": "zendy199x",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zendy199x/jira-team-work-log-tracking.git"
  },
  "homepage": "https://github.com/zendy199x/jira-team-work-log-tracking#readme",
  "bugs": {
    "url": "https://github.com/zendy199x/jira-team-work-log-tracking/issues"
  },
  "keywords": [
    "nestjs",
    "jira",
    "worklog",
    "tracking",
    "google-chat",
    "vercel"
  ],
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage --runInBand",
    "test:ci": "jest --config jest.config.cjs --ci --runInBand",
    "check:legacy-phrases": "sh -c 'if grep -rnE \"LOGWORK REPORT|Logwork Report\" README.md src/report/domain/value-objects.ts src/health.controller.ts; then echo \"Found legacy phrases\"; exit 1; else echo \"No legacy phrases found\"; fi'",
    "ci:verify": "pnpm run test:coverage && pnpm run build && pnpm run check:legacy-phrases",
    "cron:run": "node dist/cron-runner.js",
    "cron:dev": "pnpm install --frozen-lockfile && pnpm run build && pnpm run cron:run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
